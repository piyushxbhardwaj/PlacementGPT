# Database configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/placementgpt
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=placementgpt

# JWT Auth
JWT_SECRET_KEY=supersecretjwtkeyforplacementgptdevelopment123!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Gemini API Key
GEMINI_API_KEY=

# Seed admin user
FIRST_ADMIN_EMAIL=admin@placementgpt.com
FIRST_ADMIN_PASSWORD=AdminSecurePass123!

# App Environment
ENV=development
PORT=8000
